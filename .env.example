# Supabase Configuration
VITE_SUPABASE_URL=https://your-supabase-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# API Keys for Transcription and Extraction
VITE_GROQ_API_KEY=your-groq-api-key-here
VITE_GEMINI_API_KEY=your-gemini-api-key-here

# Razorpay Configuration
# Safe to expose in the browser bundle
VITE_RAZORPAY_KEY_ID=your-razorpay-key-id-here

# Server-side only. Never expose this in client-side code.
RAZORPAY_KEY_SECRET=your-razorpay-secret-here
