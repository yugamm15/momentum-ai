{
  "manifest_version": 3,
  "name": "Momentum AI",
  "version": "1.0",
  "description": "AI meeting assistant for Google Meet",
  
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://meet.google.com/*",
    "http://localhost:5173/*"
  ],

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*"],
      "js": ["content.js"]
    },
    {
      "matches": ["http://localhost:5173/*"],
      "js": ["dashboard-content.js"]
    }
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Moméntum AI",
    "default_icon": {
      "16": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },

  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  }
}
